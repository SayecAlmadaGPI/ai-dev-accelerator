{
  "name": "AI Dev Accelerator (Starlight)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "npm install",
  "forwardPorts": [4321],
  "portsAttributes": {
    "4321": { "label": "Astro dev", "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": ["astro-build.astro-vscode"]
    }
  },
  "remoteUser": "node"
}
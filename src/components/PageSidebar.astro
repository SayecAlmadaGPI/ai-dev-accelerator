---
// Override de PageSidebar (rediseño e-learning).
// Panel derecho con metadata del módulo/lab actual, recursos relacionados,
// tags, y TOC. Estilo plataforma e-learning (imagen 1: panel derecho con
// info del curso, instructor, tags, descripción, contenido).
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';
import TableOfContents from 'virtual:starlight/components/TableOfContents';
import ProgressRing from './ProgressRing.astro';
import trackable from '../data/trackable.json';
import { quizBySlug } from '../data/quizzes';

const base = import.meta.env.BASE_URL;
const { toc, entry, hasSidebar } = Astro.locals.starlightRoute;
const title = entry.data.title;

// Derivar slug actual (igual que PageTitle)
let slug = Astro.url.pathname;
if (slug.startsWith(base)) slug = slug.slice(base.length);
slug = slug.replace(/\/+$/, '');

const isTrackable = trackable.some((t) => t.slug === slug);
const quiz = quizBySlug[slug];
const relatedLabs = trackable.filter((t) => t.group === 'labs');

// Tags simples basados en el título.
const tags: string[] = [];
if (slug.includes('modules/00')) tags.push('Fundamentos');
else if (slug.includes('modules/01')) tags.push('Mentalidad', 'Harness');
else if (slug.includes('modules/02')) tags.push('Spec-Driven', 'SDD');
else if (slug.includes('modules/03')) tags.push('Workbench');
else if (slug.includes('modules/04')) tags.push('Handoffs');
else if (slug.includes('modules/05')) tags.push('MCP', 'Tools');
else if (slug.includes('modules/06')) tags.push('Verificación', 'Testing');
else if (slug.includes('modules/07')) tags.push('Failure Modes');
else if (slug.includes('modules/08')) tags.push('Casos de Uso');
else if (slug.includes('modules/09')) tags.push('Evaluación', 'Benchmarks');
else if (slug.includes('modules/10')) tags.push('Seguridad', 'Governance');
else if (slug.includes('lab-')) tags.push('Práctica', 'Lab');
else tags.push('Curso');

// Nivel de dificultad basado en el número de módulo.
let difficulty = 'Principiante';
const modNum = parseInt(slug.match(/modules\/(\d+)/)?.[1] || '0', 10);
if (modNum >= 7) difficulty = 'Avanzado';
else if (modNum >= 4) difficulty = 'Intermedio';

// Widgets de práctica contextual embebidos en el panel derecho.
// Cada slug puede tener uno o más widgets (terminal fake o playground).
interface Widget { type: 'sim' | 'play'; id: string; label: string }
const widgets: Widget[] = [];
if (slug === 'modules/02-spec-plan-execute')
  widgets.push({ type: 'play', id: 'filterByDate', label: 'filterByDate en vivo' });
if (slug === 'modules/03-workbench')
  widgets.push({ type: 'sim', id: 'm3-workbench', label: 'Workbench interactivo' });
if (slug === 'modules/06-verificacion') {
  widgets.push({ type: 'play', id: 'mutation-testing', label: 'Mutation testing mini' });
  widgets.push({ type: 'sim', id: 'm6-verify', label: 'Verificación interactiva' });
}
if (slug === 'labs/lab-01-baseline-vs-harness')
  widgets.push({ type: 'sim', id: 'lab-01', label: 'Lab 01 interactivo' });
if (slug === 'labs/lab-02-spec-driven-feature') {
  widgets.push({ type: 'sim', id: 'lab-02', label: 'Lab 02 interactivo' });
  widgets.push({ type: 'play', id: 'task-store', label: 'task-store en vivo' });
}
---

{
  toc && (
    <>
      <div class="lg:sl-hidden">
        <MobileTableOfContents />
      </div>
      <div class="right-sidebar-panel sl-hidden lg:sl-block" data-right-panel>
        {widgets.length > 0 && (
          <button
            type="button"
            class="rp-toggle"
            data-rp-toggle
            aria-label="Contraer panel de práctica"
            aria-expanded="true"
          >
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6" class="rp-chevron-right" />
              <path d="M9 18l6-6-6-6" class="rp-chevron-left" />
            </svg>
          </button>
        )}
        <div class="sl-container">
          {/* Metadata card */}
          {isTrackable && (
            <div class="rp-card rp-meta">
              <div class="rp-meta__top">
                <ProgressRing slug={slug} />
                <div class="rp-meta__title">{title}</div>
              </div>

              <div class="rp-meta__grid">
                <div class="rp-meta__cell">
                  <span class="rp-meta__label">Nivel</span>
                  <span class="rp-meta__value">{difficulty}</span>
                </div>
                <div class="rp-meta__cell">
                  <span class="rp-meta__label">Quiz</span>
                  <span class="rp-meta__value">{quiz ? `${quiz.questions.length} preguntas` : '—'}</span>
                </div>
                <div class="rp-meta__cell">
                  <span class="rp-meta__label">Tipo</span>
                  <span class="rp-meta__value">{slug.includes('lab-') ? 'Lab práctico' : 'Módulo teórico'}</span>
                </div>
                <div class="rp-meta__cell">
                  <span class="rp-meta__label">Labs</span>
                  <span class="rp-meta__value">{relatedLabs.length}</span>
                </div>
              </div>

              {tags.length > 0 && (
                <div class="rp-tags">
                  {tags.map((t) => (
                    <span class="rp-tag">{t}</span>
                  ))}
                </div>
              )}
            </div>
          )}


          {/* Recursos relacionados (solo en módulos) */}
          {isTrackable && !slug.includes('lab-') && relatedLabs.length > 0 && (
            <div class="rp-card rp-related">
              <p class="rp-card__title">Labs relacionados</p>
              <ul class="rp-related__list">
                {relatedLabs.slice(0, 3).map((lab) => (
                  <li>
                    <a class="rp-related__link" href={`${base}${lab.slug}/`}>
                      <span class="rp-related__dot" />
                      <span>{lab.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {/* TOC */}
          <div class="rp-toc">
            <p class="rp-card__title">Contenido</p>
            <TableOfContents />
          </div>

          {/* Práctica contextual embebida */}
          {widgets.length > 0 && (
            <div class="rp-card rp-practice">
              <p class="rp-card__title">Práctica en línea</p>
              {widgets.map((w) => (
                <details class="rp-practice__item" open={widgets.length === 1}>
                  <summary class="rp-practice__summary">{w.label}</summary>
                  <div class="rp-practice__body">
                    {w.type === 'sim' ? (
                      <div data-term-mount data-scenario={w.id} ></div>
                    ) : (
                      <div data-playground-mount data-example={w.id} ></div>
                    )}
                  </div>
                </details>
              ))}
            </div>
          )}
        </div>
      </div>

      {/* Tab visible cuando el panel derecho está contraído */}
      {widgets.length > 0 && (
        <div class="rp-collapsed-tab" data-rp-tab>
          <button type="button" data-rp-toggle aria-label="Expandir panel de práctica">
            <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6" /></svg>
            <span>Práctica</span>
          </button>
        </div>
      )}

      {widgets.length > 0 && (
        <script>
          (function () {
            const STORAGE_KEY = 'aida:right-panel:collapsed';
            const html = document.documentElement;

            function setCollapsed(collapsed) {
              html.toggleAttribute('data-right-panel-collapsed', collapsed);
              document.querySelectorAll('[data-rp-toggle]').forEach((btn) => {
                btn.setAttribute('aria-expanded', String(!collapsed));
              });
              try { localStorage.setItem(STORAGE_KEY, String(collapsed)); } catch {}
            }

            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored === 'true') setCollapsed(true);
            html.setAttribute('data-has-widgets', 'true');

            document.querySelectorAll('[data-rp-toggle]').forEach((btn) => {
              btn.addEventListener('click', () => {
                setCollapsed(!html.hasAttribute('data-right-panel-collapsed'));
              });
            });
          })();
        </script>
      )}
    </>
  )
}

<style>
  .right-sidebar-panel {
    padding: 1rem var(--sl-sidebar-pad-x);
  }
  .sl-container {
    width: calc(var(--sl-sidebar-width) - 2 * var(--sl-sidebar-pad-x));
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Cards del panel derecho */
  .rp-card {
    padding: 1rem;
    border-radius: 14px;
    border: 1px solid var(--sl-color-hairline);
    background: color-mix(in srgb, var(--sl-color-bg-sidebar) 60%, transparent);
  }
  .rp-card__title {
    margin: 0 0 0.7rem;
    font-size: var(--sl-text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sl-color-gray-3);
  }

  /* Metadata */
  .rp-meta__top {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--sl-color-hairline-shade);
  }
  .rp-meta__title {
    font-weight: 700;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-white);
    line-height: 1.3;
  }
  .rp-meta__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem 0.8rem;
  }
  .rp-meta__cell {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .rp-meta__label {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .rp-meta__value {
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-white);
  }
  .rp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.8rem;
  }
  .rp-tag {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-text-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  /* Toggle del panel derecho */
  .rp-toggle {
    position: absolute;
    top: 0.6rem;
    left: -14px;
    z-index: 55;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--sl-color-hairline-shade);
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-2);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, transform 0.15s ease;
    box-shadow: var(--sl-shadow-sm);
    padding: 0;
  }
  .rp-toggle:hover {
    background: var(--sl-color-accent);
    color: #1a1208;
    transform: scale(1.08);
  }
  .rp-toggle:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }
  .rp-toggle .rp-chevron-left {
    display: none;
  }
  html[data-right-panel-collapsed] .rp-toggle {
    display: none;
  }

  /* Tab colapsado (visible cuando el panel está oculto) */
  .rp-collapsed-tab {
    display: none;
    position: fixed;
    inset-inline-end: 0;
    inset-block-start: calc(var(--sl-nav-height) + 12px);
    z-index: 55;
  }
  html[data-right-panel-collapsed] .rp-collapsed-tab {
    display: block;
  }
  .rp-collapsed-tab button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.7rem 0.45rem 0.55rem;
    border-start-start-radius: 999px;
    border-end-start-radius: 999px;
    border: 1px solid var(--sl-color-hairline-shade);
    border-inline-end: none;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    cursor: pointer;
    box-shadow: var(--sl-shadow-sm);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .rp-collapsed-tab button:hover {
    background: var(--sl-color-accent);
    color: #1a1208;
  }

  /* Recursos relacionados */
  .rp-related__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .rp-related__link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.4rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .rp-related__link:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
    color: var(--sl-color-white);
  }
  .rp-related__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--sl-color-accent);
    flex-shrink: 0;
  }

  /* TOC */
  .rp-toc :global(h2) {
    display: none; /* ocultamos el h2 "En esta página" de Starlight */
  }
  .rp-toc :global(:where(a)) {
    display: block;
    font-size: var(--sl-text-xs);
    text-decoration: none;
    color: var(--sl-color-gray-3);
    overflow-wrap: anywhere;
    padding: 0.3rem 0;
    border-left: 2px solid transparent;
    padding-left: 0.6rem;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .rp-toc :global(:where(a):hover) {
    color: var(--sl-color-white);
    border-left-color: color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
  }
  .rp-toc :global(:where(a[aria-current='true'])) {
    color: var(--sl-color-white);
    font-weight: 600;
    border-left-color: var(--sl-color-accent);
  }

  /* Práctica contextual embebida */
  .rp-practice {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .rp-practice__item {
    border: 1px solid var(--sl-color-hairline-shade);
    border-radius: 10px;
    overflow: hidden;
  }
  .rp-practice__summary {
    padding: 0.5rem 0.7rem;
    font-size: var(--sl-text-sm);
    font-weight: 600;
    color: var(--sl-color-white);
    cursor: pointer;
    user-select: none;
    list-style: none;
    background: color-mix(in srgb, var(--sl-color-accent) 8%, transparent);
  }
  .rp-practice__summary::-webkit-details-marker {
    display: none;
  }
  .rp-practice__body {
    padding: 0.5rem;
  }

  /* Overrides compactos para terminal y playground dentro del panel derecho */
  .rp-practice__body :global(.aida-term) {
    height: 16rem;
    margin-top: 0;
    border-radius: 8px;
  }
  .rp-practice__body :global(.aida-term__bar) {
    padding: 0.35rem 0.5rem;
    gap: 0.4rem;
  }
  .rp-practice__body :global(.aida-term__sel-label) {
    display: none;
  }
  .rp-practice__body :global(.aida-term__hint) {
    display: none;
  }
  .rp-practice__body :global(.aida-term__screen) {
    padding: 0.5rem;
    font-size: 12px;
  }
  .rp-practice__body :global(.aida-term__inputline) {
    padding: 0.4rem 0.5rem;
  }
  .rp-practice__body :global(.aida-term__prompt),
  .rp-practice__body :global(.aida-term__input) {
    font-size: 12px;
  }

  .rp-practice__body :global(.aida-pg) {
    margin-top: 0;
    gap: 0.4rem;
  }
  .rp-practice__body :global(.aida-pg__bar) {
    gap: 0.4rem;
  }
  .rp-practice__body :global(.aida-pg__sel-label) {
    display: none;
  }
  .rp-practice__body :global(.aida-pg__editor) {
    min-height: 8rem;
    padding: 0.5rem;
    font-size: 12px;
  }
  .rp-practice__body :global(.aida-pg__out) {
    min-height: 4rem;
    max-height: 10rem;
    padding: 0.5rem;
    font-size: 12px;
  }
  .rp-practice__body :global(.aida-pg__controls) {
    gap: 0.4rem;
  }

  @media (min-width: 72rem) {
    .sl-container {
      max-width: calc(
        (
          (
              100vw - var(--sl-sidebar-width) - 2 * var(--sl-content-pad-x) - 2 *
                var(--sl-sidebar-pad-x)
            ) * 0.25
        )
      );
    }
  }
</style>